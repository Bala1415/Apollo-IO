# ========================================================
# APOLLO-IO PRODUCTION CONFIGURATION TEMPLATE
# ========================================================

# 1. Environment and Base Settings
ENVIRONMENT=development
# Generate a secret key using: openssl rand -hex 32
SECRET_KEY=replace_this_with_a_secure_random_string_32_characters_minimum

# 2. Database Connection
# If using the Docker Compose stack, use these defaults.
# If hosting externally (e.g. AWS RDS), replace with your real URL.
DATABASE_URL=postgresql://postgres:postgres@db:5432/apollo

# 3. Redis / Queue Connection
# Used for distributed caching and the background worker queue
REDIS_URL=redis://redis:6379/0

# 4. Third-Party API Keys (Required for AI Agents & Providers)
# Replace these placeholders with your actual keys from the respective dashboards.

# LLM Provider (Required for the Supervisor & Agents)
OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Research Agent (Tavily/SerpAPI for web search)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Notification Provider (SendGrid/AWS SES for email alerts)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
